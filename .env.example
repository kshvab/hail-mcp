# hail — copy to .env and set a strong key.
#   cp .env.example .env

# HTTP port; the MCP endpoint is /mcp.
PORT=9091

# The single shared key gating the whole MCP surface. REQUIRED.
# The server refuses to start if this is unset or left as "changeme".
# Every peer must present it as the X-Api-Key header in its MCP config.
X_API_KEY=changeme

# Optional: set DEBUG=1 for a verbose per-request wire/push trace.
# DEBUG=1
